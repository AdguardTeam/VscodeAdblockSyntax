{
    "name": "adblock",
    "displayName": "Adblock/AdGuard/uBlock filters grammar",
    "description": "VS code extension that adds support for ad blocking rules syntax.",
    "version": "2.0.4",
    "publisher": "adguard",
    "icon": "icons/aglint_128x128.png",
    "main": "./client/out/extension",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/AdguardTeam/VscodeAdblockSyntax.git"
    },
    "bugs": {
        "url": "https://github.com/AdguardTeam/VscodeAdblockSyntax/issues"
    },
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": "limited",
            "description": "Only syntax highlighting supported."
        },
        "virtualWorkspaces": {
            "supported": "limited",
            "description": "Only syntax highlighting supported. Linter uses Node.js filesystem API, which is not supported in virtual workspaces."
        }
    },
    "contributes": {
        "languages": [
            {
                "id": "adblock",
                "aliases": [
                    "adblock",
                    "adguard",
                    "ublock"
                ],
                "extensions": [
                    ".txt"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "adblock",
                "scopeName": "text.adblock",
                "path": "./syntaxes/out/adblock.plist",
                "embeddedLanguages": {
                    "source.js": "javascript"
                }
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Adblock",
            "properties": {
                "adblock.enableAglint": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable AGLint integration. If disabled, only syntax highlighting and other language features will be available."
                },
                "adblock.enableInMemoryAglintCache": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "⚠️ **Experimental**: Enable or disable in-memory caching of linting results for better performance."
                }
            }
        }
    },
    "scripts": {
        "build:grammar": "pnpm --silent --filter @vscode-adblock-syntax/syntaxes build",
        "build:prod": "pnpm build:clean && pnpm --silent --filter @vscode-adblock-syntax/shared build && pnpm --silent --filter @vscode-adblock-syntax/server build --minify && pnpm --silent --filter @vscode-adblock-syntax/client build --minify && pnpm --silent --filter @vscode-adblock-syntax/syntaxes build --minify && pnpm build:vsix",
        "build:prerelease": "pnpm build:clean && pnpm --silent --filter @vscode-adblock-syntax/shared build && pnpm --silent --filter @vscode-adblock-syntax/server build --minify && pnpm --silent --filter @vscode-adblock-syntax/client build --minify && pnpm --silent --filter @vscode-adblock-syntax/syntaxes build --minify && pnpm build:vsix-prerelease",
        "build:txt": "tsx tools/build-txt.ts",
        "build:vsix": "mkdirp out && vsce package --out out/vscode-adblock.vsix",
        "build:vsix-prerelease": "mkdirp out && vsce package --out out/vscode-adblock.vsix --pre-release",
        "build:clean": "rimraf ./client/out && rimraf ./server/out && rimraf ./syntaxes/out && rimraf ./out",
        "clean": "tsx tools/clean.ts",
        "extract-changelog": "node -r esbuild-register tools/changelog-extractor.ts",
        "increment": "pnpm version patch --no-git-tag-version",
        "lint": "pnpm lint:ts && pnpm lint:md",
        "lint:md": "markdownlint .",
        "lint:staged": "lint-staged",
        "lint:ts": "eslint . --cache --ext .ts",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@typescript-eslint/eslint-plugin": "^7.5.0",
        "@typescript-eslint/parser": "^7.5.0",
        "@vscode/vsce": "^3.6.2",
        "commander": "^11.1.0",
        "esbuild": "^0.17.17",
        "esbuild-register": "^3.5.0",
        "escape-string-regexp": "^5.0.0",
        "eslint": "8.57.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-plugin-boundaries": "^5.0.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-newlines": "^1.4.0",
        "eslint-plugin-jsdoc": "^60.8.0",
        "eslint-plugin-n": "^17.23.1",
        "husky": "^9.0.1",
        "jsdoc": "^4.0.4",
        "lint-staged": "^15.1.0",
        "markdownlint": "^0.30.0",
        "markdownlint-cli": "^0.35.0",
        "mkdirp": "^3.0.1",
        "ovsx": "^0.10.6",
        "remark-inline-links": "^7.0.0",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "rimraf": "^4.1.2",
        "tsx": "^4.7.0",
        "typescript": "^5.9.2",
        "unified": "^11.0.4",
        "vscode-oniguruma": "^2.0.1",
        "vscode-textmate": "^9.0.0"
    },
    "pnpm": {
        "neverBuiltDependencies": []
    }
}
